# OKX API credentials
# Create at: OKX → Account → API Management → Create V5 key
# Permissions required: Read + Trade  |  Withdraw must stay OFF
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here

# Assets (OKX spot symbols, comma-separated, no spaces)
SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT,XRP-USDT
TIMEFRAME=1H

# Portfolio and risk limits
PORTFOLIO_VALUE_USD=1000
RISK_PER_TRADE=0.02       # 2% of portfolio per trade
MAX_TRADE_SIZE_USD=50     # hard cap per trade in USD
MAX_TRADES_PER_DAY=3

# Set to false only when ready to trade real money
PAPER_TRADING=true
